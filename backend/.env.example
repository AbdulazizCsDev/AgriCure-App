# AgriCure — backend configuration. Copy to `.env` and fill in real values.
# `.env` is git-ignored. NEVER commit real keys (especially the service_role key).

# ── Supabase (similarity store, review queue, knowledge base) ─────────────
SUPABASE_URL=https://<your-project-ref>.supabase.co
# service_role secret: Supabase dashboard -> Project Settings -> API -> service_role
SUPABASE_SERVICE_KEY=

# ── OpenAI (LLM plant-care guidance; optional — advice is omitted if unset) ─
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Reviewer dashboard access code (change me) ───────────────────────────
REVIEWER_PIN=000000

# ── Deployment mode (optional) ───────────────────────────────────────────
# Set to run the app in light "proxy" mode: the heavy CNN/CLIP models live in a
# separate service (e.g. a Hugging Face Space) and this app calls it for /predict.
# Leave unset to load models locally (full features, used in development).
# MODEL_API_URL=https://<your-model-space>.hf.space
